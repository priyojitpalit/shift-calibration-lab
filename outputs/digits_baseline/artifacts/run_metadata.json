      "adaptive_temperature": {
        "enabled": true,
        "learning_rate": 0.05,
        "max_iter": 700,
        "l2": 0.001,
        "include_severity": false
      }
    },
    "shift": {
      "families": []
    },
    "reporting": {
      "reliability_bins": 15,
      "save_probabilities": true
    }
  },
  "scalar_temperature": 0.5,
